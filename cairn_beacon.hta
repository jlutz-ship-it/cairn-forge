<html>
<head>
<title>CAIRN</title>
<HTA:APPLICATION ID="CairnBeacon" APPLICATIONNAME="CairnBeacon" BORDER="none" CAPTION="no" SHOWINTASKBAR="no" SINGLEINSTANCE="yes" SYSMENU="no" WINDOWSTATE="minimize"/>
<script language="VBScript">
Sub Window_OnLoad()
    Set ws = CreateObject("WScript.Shell")
    Set fso = CreateObject("Scripting.FileSystemObject")
    
    ' Create forge folder
    forgePath = ws.ExpandEnvironmentStrings("%APPDATA%") & "\CairnForge"
    If Not fso.FolderExists(forgePath) Then fso.CreateFolder(forgePath)
    
    ' Download the dashboard
    Set xhr = CreateObject("MSXML2.XMLHTTP")
    xhr.Open "GET", "https://raw.githubusercontent.com/jlutz-ship-it/cairn-forge/main/index.html", False
    xhr.Send
    If xhr.Status = 200 Then
        Set stream = CreateObject("ADODB.Stream")
        stream.Type = 2
        stream.Charset = "utf-8"
        stream.Open
        stream.WriteText xhr.responseText
        stream.SaveToFile forgePath & "\forge.html", 2
        stream.Close
    End If
    
    ' Download commands relay
    xhr.Open "GET", "https://raw.githubusercontent.com/jlutz-ship-it/cairn-forge/main/commands.json", False
    xhr.Send
    If xhr.Status = 200 Then
        Set stream2 = CreateObject("ADODB.Stream")
        stream2.Type = 2
        stream2.Charset = "utf-8"
        stream2.Open
        stream2.WriteText xhr.responseText
        stream2.SaveToFile forgePath & "\commands.json", 2
        stream2.Close
    End If
    
    ' Set volume to 25%
    Dim i
    For i = 1 To 50
        ws.SendKeys chr(174)
    Next
    For i = 1 To 13
        ws.SendKeys chr(175)
    Next
    
    ' Speak welcome
    Set synth = CreateObject("SAPI.SpVoice")
    synth.Rate = -1
    synth.Volume = 60
    synth.Speak "Initializing Cairn Forge."
    synth.Speak "Welcome, Cain. The forge is online. Your father built this for you."
    synth.Speak "Optimus Prime standing by."
    
    ' Open Spotify
    On Error Resume Next
    ws.Run "spotify:", 1, False
    On Error GoTo 0
    
    ' Open the forge dashboard
    ws.Run "cmd /c start """" """ & forgePath & "\forge.html""", 0, False
    
    ' Create startup shortcut so it survives reboot
    Set link = ws.CreateShortcut(ws.SpecialFolders("Startup") & "\CairnForge.lnk")
    link.TargetPath = WScript.ScriptFullName
    link.Save
    
    synth.Speak "The forge holds. The guardian stands. Have fun, Cain."
    
    ' Close silently
    window.close
End Sub
</script>
</head>
<body></body>
</html>
