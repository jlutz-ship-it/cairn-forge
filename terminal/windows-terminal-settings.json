{
    "$help": "BATTLE STATION — Windows Terminal Settings",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "defaultProfile": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
    "copyOnSelect": true,
    "theme": "Battle Station",
    "themes": [
        {
            "name": "Battle Station",
            "tab": {
                "background": "#0A0E17",
                "showCloseButton": "hover",
                "unfocusedBackground": "#060A12"
            },
            "tabRow": {
                "background": "#060A12",
                "unfocusedBackground": "#040710"
            },
            "window": {
                "applicationTheme": "dark",
                "useMica": false
            }
        }
    ],
    "schemes": [
        {
            "name": "Battle Station",
            "background": "#0A0E17",
            "foreground": "#E2E8F0",
            "cursorColor": "#FF6B1A",
            "selectionBackground": "#FF6B1A33",
            "black": "#0A0E17",
            "brightBlack": "#1E293B",
            "red": "#EF4444",
            "brightRed": "#F87171",
            "green": "#06D6A0",
            "brightGreen": "#34D399",
            "yellow": "#FFB800",
            "brightYellow": "#FCD34D",
            "blue": "#0EA5E9",
            "brightBlue": "#38BDF8",
            "purple": "#A855F7",
            "brightPurple": "#C084FC",
            "cyan": "#06D6A0",
            "brightCyan": "#2DD4BF",
            "white": "#E2E8F0",
            "brightWhite": "#F8FAFC"
        }
    ],
    "profiles": {
        "defaults": {
            "font": {
                "face": "Cascadia Code",
                "size": 12,
                "weight": "normal"
            },
            "colorScheme": "Battle Station",
            "opacity": 92,
            "useAcrylic": true,
            "acrylicOpacity": 0.88,
            "padding": "12",
            "antialiasingMode": "cleartype",
            "cursorShape": "filledBox",
            "scrollbarState": "hidden",
            "bellStyle": "none"
        },
        "list": [
            {
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "name": "PowerShell",
                "commandline": "powershell.exe -NoLogo",
                "startingDirectory": "%USERPROFILE%",
                "hidden": false
            },
            {
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "name": "PowerShell 7",
                "source": "Windows.Terminal.PowershellCore",
                "hidden": false
            },
            {
                "guid": "{0caa0dad-35be-5f56-a8ff-afceeeaa6101}",
                "name": "Command Prompt",
                "commandline": "cmd.exe",
                "hidden": false
            },
            {
                "guid": "{2c4de342-38b7-51cf-b940-2309a097f518}",
                "name": "Ubuntu",
                "source": "Windows.Terminal.Wsl",
                "hidden": false
            }
        ]
    },
    "actions": [
        { "command": "paste", "keys": "ctrl+v" },
        { "command": "copy", "keys": "ctrl+c" },
        { "command": "find", "keys": "ctrl+f" },
        { "command": { "action": "splitPane", "split": "auto" }, "keys": "alt+shift+d" },
        { "command": { "action": "splitPane", "split": "horizontal" }, "keys": "alt+shift+minus" },
        { "command": { "action": "splitPane", "split": "vertical" }, "keys": "alt+shift+plus" },
        { "command": "toggleFocusMode", "keys": "f11" },
        { "command": "newTab", "keys": "ctrl+t" },
        { "command": "closeTab", "keys": "ctrl+w" },
        { "command": { "action": "nextTab" }, "keys": "ctrl+tab" },
        { "command": { "action": "prevTab" }, "keys": "ctrl+shift+tab" },
        { "command": { "action": "moveFocus", "direction": "left" }, "keys": "alt+left" },
        { "command": { "action": "moveFocus", "direction": "right" }, "keys": "alt+right" },
        { "command": { "action": "moveFocus", "direction": "up" }, "keys": "alt+up" },
        { "command": { "action": "moveFocus", "direction": "down" }, "keys": "alt+down" },
        { "command": { "action": "adjustFontSize", "delta": 1 }, "keys": "ctrl+plus" },
        { "command": { "action": "adjustFontSize", "delta": -1 }, "keys": "ctrl+minus" }
    ]
}